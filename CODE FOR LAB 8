void logAlert( const char* sensorName, float value, const char* unit )
{

alertCount++;

char valStr[12];
floatToStr( value, 1, valStr, sizeof(valStr) );

serialPrint(&quot;Alert Logged: &quot;);
serialPrint(sensorName);
serialPrint(&quot; = &quot;);
serialPrint(valStr);
serialPrint(&quot; &quot;);
serialPrint(unit);
serialPrint(&quot;\r\n&quot;);

if ( !mountSD() ) return;

FILE* f = fopen( LOG_FILE, &quot;a&quot; );
if ( f ) {
char line[128];
snprintf( line, sizeof(line),
&quot;Alert #%d | Sensor: %s | Value: %s %s | State: ACTIVE\r\n&quot;,
alertCount, sensorName, valStr, unit );
fwrite( line, 1, strlen(line), f );
fclose(f);
} else {
serialPrint(&quot;[SD] Failed to open alerts.txt\r\n&quot;);
}

lcdClear();
lcdSetCursor(0, 0); lcdPrint(&quot;Alert Logged to SD &quot;);
char line[21];
snprintf( line, sizeof(line), &quot;%-20s&quot;, sensorName );

lcdSetCursor(0, 1); lcdPrint(line);
snprintf( line, sizeof(line), &quot;Val: %s %s &quot;, valStr, unit );
lcdSetCursor(0, 2); lcdPrint(line);
snprintf( line, sizeof(line), &quot;Alert #%d &quot;, alertCount );
lcdSetCursor(0, 3); lcdPrint(line);
ThisThread::sleep_for(2000ms);
lcdClear();
}

void readAlerts()
{
if ( !mountSD() ) return;

FILE* f = fopen( LOG_FILE, &quot;r&quot; );
if ( !f ) {
serialPrint(&quot;[SD] No alert log found yet.\r\n&quot;);
return;
}

serialPrint(&quot;\r\n========== Alert Log ==========\r\n&quot;);
char line[128];
int lineNum = 0;
while ( fgets( line, sizeof(line), f ) ) {
uartUsb.write( line, strlen(line) );
lineNum++;
}
fclose(f);

if ( lineNum == 0 ) serialPrint(&quot;(Log file is empty)\r\n&quot;);
serialPrint(&quot;================================\r\n\r\n&quot;);
}

