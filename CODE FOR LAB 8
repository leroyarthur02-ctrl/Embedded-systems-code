bool mountSD()
{
if ( sdMounted ) return true;
int err = fs.mount(&amp;sd);
if ( err ) {
serialPrint(&quot;[SD] Mount failed, attempting format...\r\n&quot;);
err = fs.reformat(&amp;sd);
if ( err ) {
serialPrint(&quot;[SD] Format failed. Check SD card.\r\n&quot;);
return false;
}
serialPrint(&quot;[SD] Format successful.\r\n&quot;);
}
sdMounted = true;
serialPrint(&quot;[SD] Mounted successfully.\r\n&quot;);
return true;
}

