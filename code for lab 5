#include "mbed.h"
#include "arm_book_lib.h"
#include <cstdio>

DigitalIn gasButton(D2);        // Alarm test input

DigitalOut alarmLED(LED1);
DigitalOut buzzer(LED2);
DigitalOut incorrectLED(LED3);


// ---------------- Keypad Connections ----------------

DigitalOut row1(D8);
DigitalOut row2(D9);
DigitalOut row3(D10);
DigitalOut row4(D11);

DigitalIn col1(D12, PullUp);
DigitalIn col2(D13, PullUp);
DigitalIn col3(D14, PullUp);
DigitalIn col4(D15, PullUp);


// ---------------- Serial Communication ----------------

UnbufferedSerial serial(USBTX, USBRX, 115200);


// ---------------- System Variables ----------------

bool alarmActive = false;
bool incorrectCode = false;

char enteredCode[5];
int codeIndex = 0;


// Correct password
const char password[] = "1805";


// RTC object
time_t currentTime;


// ---------------- Keypad Layout ----------------

char keypad[4][4] =
{
    {'1','2','3','A'},
    {'4','5','6','B'},
    {'7','8','9','C'},
    {'*','0','#','D'}
};


// ---------------- Function Definitions ----------------

void sendMessage(const char *msg)
{
    serial.write(msg, strlen(msg));
}


// Scan keypad

char readKeypad()
{
    char key = 0;


    row1 = 0;
    row2 = 1;
    row3 = 1;
    row4 = 1;

    if(!col1) key='1';
    if(!col2) key='2';
    if(!col3) key='3';
    if(!col4) key='A';


    row1 = 1;
    row2 = 0;

    if(!col1) key='4';
    if(!col2) key='5';
    if(!col3) key='6';
    if(!col4) key='B';


    row2 = 1;
    row3 = 0;

    if(!col1) key='7';
    if(!col2) key='8';
    if(!col3) key='9';
    if(!col4) key='C';


    row3 = 1;
    row4 = 0;

    if(!col1) key='*';
    if(!col2) key='0';
    if(!col3) key='#';
    if(!col4) key='D';


    row4 = 1;


    return key;
}



// Reset code entry

void clearCode()
{
    codeIndex = 0;

    for(int i=0;i<5;i++)
    {
        enteredCode[i]='\0';
    }
}



// Check entered password

void checkPassword()
{
    if(strcmp(enteredCode,password)==0)
    {
        alarmActive = false;
        incorrectLED = OFF;

        sendMessage("ACCESS GRANTED\n");
        sendMessage("Alarm Disabled\n");
    }
    else
    {
        incorrectLED = ON;

        sendMessage("INCORRECT CODE\n");
    }

    clearCode();
}



// FSM keypad handling

void keypadFSM()
{
    static bool keyPressed = false;


    char key = readKeypad();


    if(key != 0 && !keyPressed)
    {
        keyPressed = true;


        if(key == '#')
        {
            checkPassword();
        }

        else
        {
            if(codeIndex < 4)
            {
                enteredCode[codeIndex]=key;
                codeIndex++;
            }
        }


        ThisThread::sleep_for(200ms);
    }


    if(key == 0)
    {
        keyPressed=false;
    }
}



// Alarm activation

void checkAlarm()
{
    if(gasButton)
    {
        alarmActive=true;

        sendMessage("ALARM ACTIVATED\n");

        while(gasButton);
    }


    if(alarmActive)
    {
        alarmLED=!alarmLED;
        buzzer=ON;
    }
    else
    {
        alarmLED=OFF;
        buzzer=OFF;
    }
}



// Display RTC time

void showTime()
{
    currentTime=time(NULL);

    char buffer[80];

    sprintf(buffer,
    "Current Time: %s\r\n",
    ctime(&currentTime));


    sendMessage(buffer);
}



// ---------------- Main Program ----------------

int main()
{

    row1=1;
    row2=1;
    row3=1;
    row4=1;


    alarmLED=OFF;
    buzzer=OFF;
    incorrectLED=OFF;


    set_time(0);


    sendMessage("\r\nSMART HOME SECURITY SYSTEM\r\n");
    sendMessage("Enter 4 digit code followed by #\r\n");


    while(true)
    {

        checkAlarm();


        keypadFSM();


        if(serial.readable())
        {
            char command;

            serial.read(&command,1);


            if(command=='t')
            {
                showTime();
            }
        }


        ThisThread::sleep_for(100ms);
    }
}
